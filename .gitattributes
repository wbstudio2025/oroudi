# Normalize text files to LF in the repository (Linux/Cloudflare build friendly),
# while letting each OS check out its native line endings.
* text=auto

# Windows launch scripts must stay CRLF wherever they are checked out.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.vbs text eol=crlf

# Binary assets: never apply line-ending or text conversion.
*.png   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
