# عروضي (Oroudi) — optional local environment notes.
#
# The current simple deployment path commits public browser config directly in
# public/supabase-config.js. Keep this file only as a local scratch/template if
# you choose to generate that config another way in the future.
#
# Both values are PUBLIC (safe in the browser). Row-Level Security protects data.
# Never put service-role keys, database passwords, or private API tokens here.
SUPABASE_URL=
SUPABASE_ANON_KEY=
