# عروضي (Oroudi) — example environment for build-time config injection.
#
# These are only needed if you generate public/supabase-config.js at build time
# on Cloudflare (see DEPLOYMENT.md). For the simple path you can instead edit
# public/supabase-config.js directly (kept out of git; uploaded by wrangler).
#
# Both values are PUBLIC (safe in the browser). Row-Level Security protects data.
SUPABASE_URL=
SUPABASE_ANON_KEY=
