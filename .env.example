# عروضي (Oroudy) — example environment for build-time config injection.
#
# These are only needed if you generate supabase-config.js at build time on
# Cloudflare Pages (see DEPLOYMENT.md). For the simple path you can instead edit
# supabase-config.js directly and commit it.
#
# Both values are PUBLIC (safe in the browser). Row-Level Security protects data.
SUPABASE_URL=
SUPABASE_ANON_KEY=
